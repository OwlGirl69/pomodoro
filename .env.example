# Copy this file to .env and fill in your values.
# .env is gitignored.

# Get your file key from the Figma URL: figma.com/file/<KEY>/<name>  or  figma.com/design/<KEY>/<name>
FIGMA_FILE_KEY=

# Personal access token. Create at: figma.com → Settings → Security → Personal access tokens
# Only needs "File content" read access.
FIGMA_TOKEN=

# (Optional) Name of the frame to use as the coordinate origin.
# Text node positions in the output will be relative to this frame's top-left,
# and the frame's width/height will be reported so you can map to your 512 canvas.
# Leave blank to dump all text nodes in the file with their absolute Figma coords.
FIGMA_FRAME_NAME=
